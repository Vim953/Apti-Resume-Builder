# Server
PORT=4000
WEB_ORIGIN=http://localhost:3000

# Supabase (Postgres/Auth/Storage) — APTI house stack
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key                    # used for RLS-scoped per-request clients
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, bypasses RLS
# SUPABASE_JWT_SECRET is NOT required — the API validates tokens by calling
# supabase.auth.getUser() with the service-role key above, which works with
# both legacy (HS256) and current (ES256) Supabase signing keys.

# LLM — tiered model routing (RB-AI-05)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL_LIGHT=gemini-1.5-flash      # Tips, draft descriptions
GEMINI_MODEL_STRONG=gemini-1.5-pro       # final AI Improve, summaries

# Entitlements (RB-ENT-03) — default monthly AI credit caps
AI_CREDITS_FREE_MONTHLY=15
AI_CREDITS_PRO_MONTHLY=300

# Upstream module APIs this resume module reads from (RB-INT-*)
PROFILE_API_URL=http://localhost:4004/internal/profile
PROJECTS_API_URL=http://localhost:4001/internal/projects
CERTIFICATIONS_API_URL=http://localhost:4002/internal/certifications
SKILL_GAP_API_URL=http://localhost:4003/internal/target-roles

# Optional: override the Chromium binary used for PDF export (RB-EXP-01).
# Leave unset locally — the postinstall script downloads one automatically.
# Set this on serverless hosts using e.g. @sparticuz/chromium.
CHROMIUM_EXECUTABLE_PATH=

# Public URL for the watermark footer on Free-plan PDF exports (RB-EXP-02).
APP_URL=https://apti.in
