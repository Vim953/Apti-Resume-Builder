{
  "name": "@apti/resume-builder-api",
  "version": "0.1.0",
  "private": true,
  "description": "APTI AI Resume Builder — NestJS API (SRS v0.1)",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest",
    "postinstall": "node node_modules/playwright-core/cli.js install chromium || echo 'Skipping Chromium download (offline or restricted network) — PDF export requires it. Run: npx playwright-core install chromium'"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/throttler": "^6.2.1",
    "@supabase/supabase-js": "^2.45.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "playwright-core": "^1.47.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "@nestjs/cli": "^10.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.16.5"
    "@nestjs/testing": "^10.4.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
